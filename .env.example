# Application Environment Variables
# Copy this file to .env and update with your actual values

# Application Configuration
APP_NAME=app-tpl
APP_VERSION=1.0.0
APP_ENV=development

# HTTP Server Configuration
HTTP_ENABLED=true
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=10s

# TCP Server Configuration
TCP_ENABLED=false
TCP_HOST=0.0.0.0
TCP_PORT=9000

# UDP Server Configuration
UDP_ENABLED=false
UDP_HOST=0.0.0.0
UDP_PORT=9001

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILENAME=
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=28
LOG_COMPRESS=true

# Database Configuration
DATABASE_ENABLED=true
DATABASE_DRIVER=sqlite
# For SQLite
DATABASE_HOST=
DATABASE_PORT=0
DATABASE_DATABASE=./data/app.db
# For MySQL
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_DATABASE=app_db
# For PostgreSQL
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_DATABASE=app_db
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_SSL_MODE=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m

# Redis Configuration
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

# Docker Compose Configuration
VERSION=1.0.0
HTTP_PORT=8080
TCP_PORT=9000
UDP_PORT=9001
DATABASE_ENABLED=true
DATABASE_DRIVER=sqlite
REDIS_ENABLED=false
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=myapp
MYSQL_USER=myapp
MYSQL_PASSWORD=app_password
MYSQL_PORT=3306
POSTGRES_DB=myapp
POSTGRES_USER=myapp
POSTGRES_PASSWORD=app_password
POSTGRES_PORT=5432
REDIS_PORT=6379
REDIS_PASSWORD=
