# Environment variables for sensitive data only
# These values override the corresponding fields in config files
#
# Note: APP_ENV should NOT be set here. Use --env flag or system environment variable.
#
# Files are loaded in this order (later values override earlier ones):
#   1. .env.{env} or ./configs/.env.{env} (env-specific)
#   2. .env or ./configs/.env (generic)

# Database sensitive configuration
DATABASE_PASSWORD=your_database_password_here

# Redis sensitive configuration
REDIS_PASSWORD=your_redis_password_here
